# krunch plan --target ray — Ray app (run-id {{ run_id }}): workers + finalize.
# Run on a Ray cluster:  ray job submit --working-dir . -- python this_file
import os
import subprocess
import ray


N_WORKERS  = {{ n_workers }}
MODE       = "{{ mode }}"
INPUT_URL  = "{{ input_url }}"
OUTPUT_URL = "{{ output_url }}"
INPUT_LEN  = {{ input_len }}
IMAGE      = "{{ image }}"


def _env(extra):
    return {**os.environ, **extra}


@ray.remote(num_gpus=1, num_cpus={{ cpus }}, memory={{ memory_mb }} * 1024 * 1024)
def worker(part_index: int):
    subprocess.check_call(
        ["docker", "run", "--rm", "--gpus", "all",
         "-e", f"KRUNCH_MODE={MODE}",
         "-e", f"KRUNCH_INPUT_URL={INPUT_URL}",
         "-e", f"KRUNCH_OUTPUT_URL={OUTPUT_URL}",
         "-e", f"KRUNCH_INPUT_LEN={INPUT_LEN}",
         "-e", f"KRUNCH_PART_COUNT={N_WORKERS}",
         "-e", f"KRUNCH_PART_INDEX={part_index}",
         "--entrypoint", "python", IMAGE, "-m", "krunch.job"])


@ray.remote(num_cpus=2)
def finalize():
    subprocess.check_call(
        ["docker", "run", "--rm",
         "-e", "KRUNCH_MODE=finalize",
         "-e", f"KRUNCH_FINALIZE_OF={MODE}",
         "-e", f"KRUNCH_INPUT_URL={INPUT_URL}",
         "-e", f"KRUNCH_OUTPUT_URL={OUTPUT_URL}",
         "-e", f"KRUNCH_INPUT_LEN={INPUT_LEN}",
         "-e", f"KRUNCH_PART_COUNT={N_WORKERS}",
         "--entrypoint", "python", IMAGE, "-m", "krunch.job"])


if __name__ == "__main__":
    ray.init(address="auto")
    ray.get([worker.remote(i) for i in range(N_WORKERS)])
    ray.get(finalize.remote())
