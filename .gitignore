# Virtual environments
.venv/
venv/
env/
*.pyc
__pycache__/
.Python
*.egg-info/

# Vendored dependencies (set up via scripts/setup.sh)
vendor/

# CDK build artifacts — never commit
cdk/node_modules/
cdk/cdk.out/
cdk/dist/
*.tsbuildinfo

# Large archived artifacts from krunch era (not needed in Krunch)
corpus_build/
data/
checkpoints-phase11/
tokenizer_pile/
tokenizer_balanced_32k/
tokenizer_pile_32k/
krunch-rust/target/
krunch-rust/fuzz/

# Test corpora (downloaded via scripts/download_corpora.sh, too big for git)
bench/corpora/*
!bench/corpora/.gitkeep
!bench/corpora/README.md

# Compressed output files (artifacts of running the benchmark)
*.gz
*.bz2
*.xz
*.zst
*.zstd
*.krunch
bench/work/

# Benchmark results (keep committed runs but gitignore scratch)
bench/results/scratch/
bench/results/*.tmp

# Editor / OS artifacts
.DS_Store
.idea/
.vscode/
*.swp
*~

# Logs
*.log

# Rust build artifacts
target/
**/target/
*.rs.bk
Cargo.lock.bak

# Converted checkpoint binaries — regeneratable from the .pth files
# via scripts/convert_checkpoint.py; too big for git (~13 MB each)
krunch-rust/checkpoints/*.bin
# Distillation fine-tuned checkpoints (Phase 4e) — produced by
# scripts/distill_krunch.py from the shipped Krunch checkpoint.
# Regeneratable via the script, not worth storing in git.
krunch-rust/checkpoints/*_distilled.pth
krunch-rust/checkpoints/*_distilled.epoch*.pth
krunch-rust/checkpoints/krunch_1l96h.bin
bench/corpora/eval_suite/
corpus_build/
cdk/outputs*.json
