#!/usr/bin/env python3
"""
krunch — neural compression CLI.

Commands:
  krunch compress    < input  > output      Single-shot compress on local GPU
  krunch decompress  < input  > output      Single-shot decompress on local GPU
  krunch submit      --source URL --dest URL [--workers N]   Distributed via AWS Batch
  krunch status      --job-id ID                             Check Batch job status

`compress` / `decompress` shell out to Docker. Default image is
ghcr.io/dmatth1/krunch:latest; override with KRUNCH_IMAGE env var.

`submit` requires boto3 + AWS credentials with Batch + S3 permissions.
"""

import argparse
import json
import os
import subprocess
import sys
import time

DEFAULT_IMAGE = os.environ.get("KRUNCH_IMAGE", "ghcr.io/dmatth1/krunch:latest")


# ---------------------------------------------------------------------------
# compress / decompress — single-shot, shell out to Docker
# ---------------------------------------------------------------------------

def cmd_compress(args):
    return _run_local("compress", args)


def cmd_decompress(args):
    return _run_local("decompress", args)


def cmd_warmup(args):
    """Materialize first-call costs (WKV `ninja` build, torch.compile graph
    trace) into a persistent docker volume so subsequent compress/decompress
    runs don't pay them. Without this, every cold-container run pays
    ~30-45 s of WKV kernel build + ~10-30 s of torch.compile trace.
    """
    if not _has_docker():
        print("Error: docker not found on PATH", file=sys.stderr)
        return 1

    cache_volume = "krunch-cache"
    # Ensure the volume exists (idempotent).
    subprocess.run(["docker", "volume", "create", cache_volume],
                   check=False, capture_output=True)

    # Compress a tiny synthetic input to force WKV build + torch.compile
    # trace + model load into the cache. The volume mounts /root/.cache,
    # which is where torch_extensions and inductor stash artifacts.
    cmd = [
        "docker", "run", "--rm", "--gpus", "all", "-i",
        "-v", f"{cache_volume}:/root/.cache",
        DEFAULT_IMAGE, "compress",
    ]
    if args.dry_run:
        print(f"docker volume create {cache_volume}")
        print(" ".join(cmd) + "  # stdin=<256 bytes synthetic>, stdout=/dev/null")
        return 0

    print(f"krunch warmup: priming '{cache_volume}' "
          f"(one-time, ~60-90 s) ...", file=sys.stderr)
    payload = (b"warmup " * 32)[:256]
    try:
        result = subprocess.run(
            cmd, input=payload, capture_output=True, timeout=300)
    except subprocess.TimeoutExpired:
        print("Error: warmup timed out after 5 min", file=sys.stderr)
        return 1
    if result.returncode != 0:
        print(f"Error: warmup compress exited {result.returncode}", file=sys.stderr)
        sys.stderr.buffer.write(result.stderr)
        return result.returncode
    print(f"krunch warmup: done. ({len(result.stdout)} compressed bytes "
          f"discarded)", file=sys.stderr)
    return 0


def _run_local(action: str, args) -> int:
    if not _has_docker():
        print("Error: docker not found on PATH", file=sys.stderr)
        return 1

    # Mount the warmup cache volume if it exists, so cold containers reuse
    # the WKV-kernel `.so` and torch.compile artifacts written by
    # `krunch warmup`. If the volume doesn't exist yet, docker auto-creates
    # an empty one — same as no warmup, just slower first run.
    cmd = [
        "docker", "run", "--rm", "--gpus", "all", "-i",
        "-v", "krunch-cache:/root/.cache",
    ]
    # Pass through any KRUNCH_* env var to the container so flags like
    # KRUNCH_CPP_GRAPH, KRUNCH_OWN_WKV, KRUNCH_DECOMPRESS_BATCH, etc.
    # can be toggled from the host without rebuilding the image.
    # Skip KRUNCH_IMAGE (host-only — the wrapper itself reads it).
    for k, v in os.environ.items():
        if k.startswith("KRUNCH_") and k != "KRUNCH_IMAGE":
            cmd += ["-e", f"{k}={v}"]
    cmd += [DEFAULT_IMAGE, action]

    # Pass file handles to subprocess only when explicit file args are
    # provided. Otherwise let subprocess inherit the parent's stdin/stdout
    # (the OS-level FDs from the shell's `< in > out` redirects). Passing
    # sys.stdin/sys.stdout explicitly created subtle stdio-buffering
    # corruption on large binary streams; inheriting just works.
    kwargs: dict = {}
    in_handle = None
    out_handle = None

    if args.input:
        try:
            in_handle = open(args.input, "rb")
            kwargs["stdin"] = in_handle
        except OSError as e:
            print(f"Error: cannot open input '{args.input}': {e}", file=sys.stderr)
            return 1

    if args.out:
        try:
            out_handle = open(args.out, "wb")
            kwargs["stdout"] = out_handle
        except OSError as e:
            print(f"Error: cannot open output '{args.out}': {e}", file=sys.stderr)
            if in_handle: in_handle.close()
            return 1

    if args.dry_run:
        in_label = args.input or "<inherit stdin>"
        out_label = args.out or "<inherit stdout>"
        print(f"docker run --rm --gpus all -i {DEFAULT_IMAGE} {action}  "
              f"# stdin={in_label}, stdout={out_label}")
        if in_handle: in_handle.close()
        if out_handle: out_handle.close()
        return 0

    try:
        return subprocess.run(cmd, **kwargs).returncode
    except KeyboardInterrupt:
        return 130
    finally:
        if in_handle: in_handle.close()
        if out_handle: out_handle.close()


def _has_docker() -> bool:
    try:
        subprocess.run(["docker", "--version"], check=True, capture_output=True)
        return True
    except (FileNotFoundError, subprocess.CalledProcessError):
        return False


# ---------------------------------------------------------------------------
# plan — render a runnable artifact for the user's batch system
# ---------------------------------------------------------------------------

def cmd_plan(args):
    """Render a per-target launch artifact via the in-image plan
    renderer. Templates live in the Docker image so we never have to
    keep host-side and image-side copies in sync."""
    docker_args = [
        "docker", "run", "--rm",
        "--entrypoint", "python",
        DEFAULT_IMAGE, "-m", "krunch.plan_cli",
        "--target", args.target,
        "--mode", args.mode,
        "--source", args.input_url,
        "--dest", args.output_url,
        "--workers", str(args.workers),
        "--image", args.image,
        "--queue", args.queue,
        "--job-definition", args.job_definition,
        "--cpus", str(args.cpus),
        "--gpus", str(args.gpus),
        "--memory-mb", str(args.memory_mb),
        "--timeout-s", str(args.timeout_s),
        "--input-len", str(args.input_len),
    ]
    if args.run_id:
        docker_args += ["--run-id", args.run_id]
    if args.dry_run:
        docker_args += ["--dry-run"]
    return subprocess.call(docker_args)


# ---------------------------------------------------------------------------
# submit
# ---------------------------------------------------------------------------

def cmd_submit(args):
    from pathlib import Path
    sys.path.insert(0, str(Path(__file__).parent.parent))
    from server import url_io

    # Build the two job-submission payloads
    job_tag = f"job-{int(time.time())}"
    parts_prefix = f"{args.dest}.parts/{job_tag}"

    compress_env = [
        {"name": "KRUNCH_JOB_TYPE",    "value": "compress"},
        {"name": "KRUNCH_SOURCE",      "value": args.source},
        {"name": "KRUNCH_TOTAL_TASKS", "value": str(args.workers)},
        {"name": "KRUNCH_PARTS_PREFIX","value": parts_prefix},
    ]
    assemble_env = [
        {"name": "KRUNCH_JOB_TYPE",     "value": "assemble"},
        {"name": "KRUNCH_PARTS_PREFIX", "value": parts_prefix},
        {"name": "KRUNCH_N_PARTS",      "value": str(args.workers)},
        {"name": "KRUNCH_DEST",         "value": args.dest},
    ]
    if args.chunk_size:
        # Override the default 1 MB chunk size on both jobs (assemble must
        # see the same value to stitch entries correctly).
        cs = {"name": "KRUNCH_CHUNK_SIZE", "value": str(args.chunk_size)}
        compress_env.append(cs)
        assemble_env.append(cs)

    compress_payload = {
        "jobName": f"krunch-compress-{job_tag}",
        "arrayProperties": {"size": args.workers},
        "containerOverrides": {"environment": compress_env},
    }
    assemble_payload = {
        "jobName": f"krunch-assemble-{job_tag}",
        "containerOverrides": {"environment": assemble_env},
    }

    if args.dry_run:
        print(json.dumps({
            "stack": args.stack,
            "source": args.source,
            "dest": args.dest,
            "workers": args.workers,
            "spot": args.spot,
            "compress_job": compress_payload,
            "assemble_job": assemble_payload,
        }, indent=2))
        return 0

    import boto3
    job_queue, compress_jd, assemble_jd = _resolve_resources(
        args.stack, args.job_queue, args.compress_job_def, args.assemble_job_def
    )

    print(f"Source:      {args.source}")
    print(f"Dest:        {args.dest}")
    print(f"Workers:     {args.workers}")
    print(f"Job queue:   {job_queue}")

    print("Getting file size...", end=" ", flush=True)
    total_size = url_io.size(args.source)
    print(f"{total_size:,} bytes ({total_size / 1024**3:.2f} GB)")

    batch = boto3.client("batch")

    # Add the resolved size + queue/def references to the payloads
    compress_payload["containerOverrides"]["environment"].append(
        {"name": "KRUNCH_TOTAL_SIZE", "value": str(total_size)}
    )
    assemble_payload["containerOverrides"]["environment"].append(
        {"name": "KRUNCH_ORIGINAL_LEN", "value": str(total_size)}
    )

    print(f"\nSubmitting compress array job ({args.workers} tasks)...")
    compress_resp = batch.submit_job(
        jobQueue=job_queue,
        jobDefinition=compress_jd,
        **compress_payload,
    )
    compress_job_id = compress_resp["jobId"]
    print(f"Compress job ID: {compress_job_id}")

    # ---------------------------------------------------------------------------
    # Poll compress job
    # ---------------------------------------------------------------------------
    print("Waiting for compress tasks to complete...")
    t0 = time.time()
    _poll_job(batch, compress_job_id, total_tasks=args.workers)
    compress_elapsed = time.time() - t0
    throughput = total_size / 1024 / compress_elapsed
    print(f"Compress done in {compress_elapsed:.0f}s ({throughput:.0f} KB/s aggregate)")

    # ---------------------------------------------------------------------------
    # Submit assemble job
    # ---------------------------------------------------------------------------
    print("\nSubmitting assemble job...")
    assemble_resp = batch.submit_job(
        jobQueue=job_queue,
        jobDefinition=assemble_jd,
        dependsOn=[{"jobId": compress_job_id, "type": "SEQUENTIAL"}],
        **assemble_payload,
    )
    assemble_job_id = assemble_resp["jobId"]
    print(f"Assemble job ID: {assemble_job_id}")

    _poll_job(batch, assemble_job_id, total_tasks=1)
    total_elapsed = time.time() - t0

    # ---------------------------------------------------------------------------
    # Report
    # ---------------------------------------------------------------------------
    try:
        dest_size = url_io.size(args.dest)
        ratio = dest_size / total_size
        print(f"\n{'='*50}")
        print(f"Done in {total_elapsed:.0f}s")
        print(f"  Original:   {total_size:,} bytes")
        print(f"  Compressed: {dest_size:,} bytes")
        print(f"  Ratio:      {ratio:.4f} ({ratio*100:.1f}% of original)")
        print(f"  Output:     {args.dest}")
    except Exception:
        print(f"\nDone in {total_elapsed:.0f}s → {args.dest}")


# ---------------------------------------------------------------------------
# status
# ---------------------------------------------------------------------------

def cmd_status(args):
    import boto3
    batch = boto3.client("batch")
    resp = batch.describe_jobs(jobs=[args.job_id])
    if not resp["jobs"]:
        print(f"Job {args.job_id} not found")
        sys.exit(1)
    job = resp["jobs"][0]
    print(json.dumps({
        "jobId": job["jobId"],
        "jobName": job["jobName"],
        "status": job["status"],
        "statusReason": job.get("statusReason", ""),
        "createdAt": job.get("createdAt"),
        "startedAt": job.get("startedAt"),
        "stoppedAt": job.get("stoppedAt"),
    }, indent=2, default=str))


# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

def _poll_job(batch, job_id: str, total_tasks: int,
              poll_interval: int = 15):
    terminal = {"SUCCEEDED", "FAILED"}
    last_status = None
    while True:
        resp = batch.describe_jobs(jobs=[job_id])
        job = resp["jobs"][0]
        status = job["status"]

        if total_tasks > 1:
            arr = job.get("arrayProperties", {}).get("statusSummary", {})
            pending = arr.get("PENDING", 0) + arr.get("RUNNABLE", 0) + arr.get("STARTING", 0)
            running = arr.get("RUNNING", 0)
            succeeded = arr.get("SUCCEEDED", 0)
            failed = arr.get("FAILED", 0)
            line = (f"  {status}: pending={pending} running={running} "
                    f"succeeded={succeeded} failed={failed}")
        else:
            line = f"  {status}"
            if "statusReason" in job:
                line += f" — {job['statusReason']}"

        if line != last_status:
            print(line)
            last_status = line

        if status in terminal:
            if status == "FAILED":
                print(f"Job {job_id} FAILED", file=sys.stderr)
                sys.exit(1)
            return

        time.sleep(poll_interval)


def _resolve_resources(stack_name, job_queue, compress_jd, assemble_jd):
    """Look up resource names from CloudFormation stack outputs if not provided."""
    if job_queue and compress_jd and assemble_jd:
        return job_queue, compress_jd, assemble_jd

    import boto3
    cf = boto3.client("cloudformation")
    resp = cf.describe_stacks(StackName=stack_name)
    outputs = {o["OutputKey"]: o["OutputValue"]
               for o in resp["Stacks"][0].get("Outputs", [])}

    return (
        job_queue   or outputs.get("JobQueueArn")          or _fail("--job-queue or --stack required"),
        compress_jd or outputs.get("CompressJobDefOutput") or _fail("--compress-job-def or --stack required"),
        assemble_jd or outputs.get("AssembleJobDefOutput") or _fail("--assemble-job-def or --stack required"),
    )


def _fail(msg):
    print(f"Error: {msg}", file=sys.stderr)
    sys.exit(1)


# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------

def main():
    parser = argparse.ArgumentParser(prog="krunch",
                                     description="Krunch neural compression CLI")
    sub = parser.add_subparsers(dest="command", required=True)

    # compress / decompress
    for action in ("compress", "decompress"):
        p = sub.add_parser(
            action,
            help=f"{action.capitalize()} a file (single GPU host via Docker)",
        )
        p.add_argument("input", nargs="?", default=None,
                       help="Input file (default: stdin)")
        p.add_argument("-o", "--out", default=None,
                       help="Output file (default: stdout)")
        p.add_argument("--dry-run", action="store_true",
                       help="Print the docker command instead of running it")

    # submit
    p_submit = sub.add_parser("submit", help="Submit a compression job")
    p_submit.add_argument("--source", required=True,
                          help="Source URL (s3://, http://, file://)")
    p_submit.add_argument("--dest", required=True,
                          help="Destination URL for compressed output")
    p_submit.add_argument("--workers", type=int, default=1,
                          help="Number of parallel compress tasks (default: 1)")
    p_submit.add_argument("--chunk-size", type=int, default=None,
                          metavar="BYTES",
                          help="Chunk size in bytes (default: 1 MB / 1048576). "
                               "Larger chunks → better ratio + amortized model "
                               "load, but worse parallelism and higher VRAM.")
    p_submit.add_argument("--spot", action=argparse.BooleanOptionalAction,
                          default=True,
                          help="Use spot instances (default: --spot)")
    p_submit.add_argument("--stack", default="KrunchStack",
                          help="CloudFormation stack name (default: KrunchStack)")
    p_submit.add_argument("--job-queue",
                          help="Batch job queue ARN or name (overrides --stack lookup)")
    p_submit.add_argument("--compress-job-def",
                          help="Batch job definition for compress tasks")
    p_submit.add_argument("--assemble-job-def",
                          help="Batch job definition for assemble task")
    p_submit.add_argument("--dry-run", action="store_true",
                          help="Print job submission payloads as JSON; don't call AWS")

    # warmup
    p_warmup = sub.add_parser(
        "warmup",
        help="Prime the local cache volume (one-time, ~60-90s post-install). "
             "Removes ~60s of cold-container costs from later compress/decompress runs.")
    p_warmup.add_argument("--dry-run", action="store_true",
                          help="Print the docker command instead of running it")

    # status
    p_status = sub.add_parser("status", help="Check job status")
    p_status.add_argument("--job-id", required=True)

    # plan — emit a runnable artifact for the user's batch system
    p_plan = sub.add_parser(
        "plan",
        help="Render a runnable artifact for any batch system (aws-batch, k8s, modal, ray, slurm, gcp-batch, local)")
    p_plan.add_argument("--target", required=True,
                        choices=["aws-batch", "k8s", "modal", "ray",
                                 "slurm", "gcp-batch", "local"])
    p_plan.add_argument("--mode", default="compress",
                        choices=["compress", "decompress"],
                        help="Whether workers compress or decompress (default: compress)")
    p_plan.add_argument("--source", "--input", dest="input_url", required=True,
                        help="Input URL (s3://, http://, file://)")
    p_plan.add_argument("--dest", "--output", dest="output_url", required=True,
                        help="Output URL")
    p_plan.add_argument("--workers", type=int, required=True,
                        help="Number of parallel worker machines. "
                             "Required — there's no universal sane default; "
                             "pick based on input size + your cluster quota + "
                             "cost target. Each worker = 1 GPU container.")
    p_plan.add_argument("--image", default=DEFAULT_IMAGE,
                        help=f"Docker image (default: {DEFAULT_IMAGE})")
    p_plan.add_argument("--queue", default="krunch-queue",
                        help="Orchestrator queue name (default: krunch-queue)")
    p_plan.add_argument("--job-definition", default="krunch-job",
                        help="AWS Batch job definition (default: krunch-job)")
    p_plan.add_argument("--cpus", type=int, default=4)
    p_plan.add_argument("--gpus", type=int, default=1)
    p_plan.add_argument("--memory-mb", type=int, default=16384)
    p_plan.add_argument("--timeout-s", type=int, default=3600)
    p_plan.add_argument("--input-len", type=int, default=0,
                        help="Input byte size; auto-detected if --source is "
                             "a real URL the CLI can stat")
    p_plan.add_argument("--run-id",
                        help="Unique run id (default: auto from time)")
    p_plan.add_argument("--dry-run", action="store_true",
                        help="Validate the artifact against schema; "
                             "print nothing if valid, error otherwise")

    args = parser.parse_args()
    handlers = {
        "compress":   cmd_compress,
        "decompress": cmd_decompress,
        "warmup":     cmd_warmup,
        "submit":     cmd_submit,
        "status":     cmd_status,
        "plan":       cmd_plan,
    }
    rc = handlers[args.command](args)
    sys.exit(rc if isinstance(rc, int) else 0)


if __name__ == "__main__":
    main()
